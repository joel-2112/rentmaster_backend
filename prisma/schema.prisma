generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  nationalId    String   @unique
  name          String
  email         String    @unique
  phone         String   @unique
  isVerified    Boolean  @default(false)
  emailVerified Boolean   @default(false)
  image         String?
  role          Role     @default(TENANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  landlordProperties Property[] @relation("LandlordProperties")
  brokerProperties Property[] @relation("BrokerProperties")
  kebeleOfficials KebeleOfficial[]
  favorites     Favorite[]
  inquiries     PropertyInquiry[]
  tenantContracts   Contract[] @relation("TenantContracts")
  landlordContracts Contract[] @relation("LandlordContracts")
  brokerContracts   Contract[] @relation("BrokerContracts")
 // paymentHistory    PaymentHistory[] @relation("PaymentsByUser")
 // receivedPayments  PaymentHistory[] @relation("PaymentsReceivedBy")
 // uploadedDocuments ContractDocument[]
  
  @@map("user")
  @@index([nationalId])
  @@index([phone])
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

enum Role {
  SUPER_ADMIN
  KEBELE_OFFICIAL
  LANDLORD
  TENANT
  BROKER
  SERVICE_PROVIDER
}


model Region {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique 
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
 
  zones       Zone[]
  cities      City[]
  woredas     Woreda[]
  kebeles     Kebele[]
  properties  Property[]

  @@map("regions")
}


model Zone {
  id          String    @id @default(cuid())
  name        String    
  code        String?   
  

  regionId    String
  region      Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt


  woredas     Woreda[]
  cities      City[]
  kebeles     Kebele[]
  properties  Property[]

  @@unique([name, regionId])
  @@map("zones")
}


model City {
  id          String    @id @default(cuid())
  name        String    
  

  regionId    String
  region      Region    @relation(fields: [regionId], references: [id])
  zoneId      String?   
  zone        Zone?     @relation(fields: [zoneId], references: [id])
  
 
  cityType    CityType  @default(CITY)
  
  
  municipalityName String?
  municipalityPhone String?
  municipalityEmail String?
  
  latitude    Float?
  longitude   Float?
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subcities   Subcity[]
  woredas     Woreda[]
  kebeles     Kebele[]
  properties  Property[]


  @@unique([name, regionId])
  @@map("cities")
}


model Subcity {
  id          String    @id @default(cuid())
  name        String   
  code        String?  
  
  cityId      String
  city        City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  
 
  officeName  String?
  officePhone String?
  officeEmail String?
  
  latitude    Float?
  longitude   Float?
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt


  woredas     Woreda[]
  kebeles     Kebele[]
  properties  Property[]


  @@unique([name, cityId])
  @@map("subcities")
}


model Woreda {
  id          String    @id @default(cuid())
  name        String   
  number      Int?     
  
 
  regionId    String
  region      Region    @relation(fields: [regionId], references: [id])
  zoneId      String?
  zone        Zone?     @relation(fields: [zoneId], references: [id])
  cityId      String?
  city        City?     @relation(fields: [cityId], references: [id])
  subcityId   String?
  subcity     Subcity?  @relation(fields: [subcityId], references: [id])
  
 
  officeName  String?
  officePhone String?
  officeEmail String?
  
 
  population  Int?
  area        Float?    
  
  latitude    Float?
  longitude   Float?
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

 
  kebeles     Kebele[]
  properties  Property[]


  @@map("woredas")
}


model Kebele {
  id          String    @id @default(cuid())
  name        String   
  number      Int?     
  

  regionId    String
  region      Region    @relation(fields: [regionId], references: [id])
  zoneId      String?
  zone        Zone?     @relation(fields: [zoneId], references: [id])
  cityId      String?
  city        City?     @relation(fields: [cityId], references: [id])
  subcityId   String?
  subcity     Subcity?  @relation(fields: [subcityId], references: [id])
  woredaId    String?
  woreda      Woreda?   @relation(fields: [woredaId], references: [id])
  

  officeName      String? 
  officePhone     String?
  officeEmail     String?
  

  officialName    String?
  officialTitle   String? 
  officialPhone   String?
  

  population      Int?
  area            Float?  
  
 
  sealImage       String?
  sealCode        String? 
  
  latitude        Float?
  longitude       Float?
  

  isActive        Boolean   @default(true)
  hasDigitalSeal  Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt


  properties      Property[]
  officials       KebeleOfficial[]
  verifiedProperties VerifiedProperty[]

  @@unique([name, woredaId])
  @@unique([name, subcityId])
  @@map("kebeles")
}


model KebeleOfficial {
  id          String    @id @default(cuid())
  

  userId      String
  user        User      @relation(fields: [userId], references: [id])
  

  kebeleId    String
  kebele      Kebele    @relation(fields: [kebeleId], references: [id])
  

  position    String   
  

  startedAt   DateTime
  endedAt     DateTime?
  isActive    Boolean   @default(true)

  verifiedProperties VerifiedProperty[]  

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, kebeleId])
  @@map("kebele_officials")
}


model VerifiedProperty {
  id          String    @id @default(cuid())
  
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  
  kebeleId    String
  kebele      Kebele    @relation(fields: [kebeleId], references: [id])
  
  officialId  String
  official    KebeleOfficial @relation(fields: [officialId], references: [id])
  

  verifiedAt  DateTime  @default(now())
  expiresAt   DateTime? 
  
 
  sealApplied Boolean   @default(true)
  sealImage   String?  
  
 
  notes       String?
  
  createdAt   DateTime  @default(now())

  @@unique([propertyId, kebeleId])
  @@map("verified_properties")
}


enum CityType {
  CITY         
  TOWN         
  ADMINISTRATION 
  SPECIAL_ZONE  
}


model Property {
  id              String    @id @default(cuid())
  title           String    @map("title")
  description     String    @map("description")
  
 
  propertyType    PropertyType @default(APARTMENT) @map("property_type")
  status          PropertyStatus @default(AVAILABLE) @map("status")
  
  
  bedrooms        Int       @default(1) @map("bedrooms")
  bathrooms       Int       @default(1) @map("bathrooms")
  area            Float     @map("area") // በካሬ ሜትር
  floor           Int?      @map("floor")
  totalFloors     Int?      @map("total_floors") // ህንጻው ጠቅላላ ፎቆች
  
  
  hasFurniture    Boolean   @default(false) @map("has_furniture")
  hasParking      Boolean   @default(false) @map("has_parking")
  hasElevator     Boolean   @default(false) @map("has_elevator")
  hasBalcony      Boolean   @default(false) @map("has_balcony")
  hasGarden       Boolean   @default(false) @map("has_garden")
  hasSecurity     Boolean   @default(false) @map("has_security")
  hasBackupGenerator Boolean @default(false) @map("has_backup_generator")
  hasWaterTank    Boolean   @default(false) @map("has_water_tank")
  
  
  monthlyRent     Float     @map("monthly_rent")
  securityDeposit Float     @map("security_deposit") 
  minimumLeaseMonths Int    @default(6) @map("minimum_lease_months")
  isNegotiable    Boolean   @default(false) @map("is_negotiable")
  
 
  landlordId      String    @map("landlord_id")
  landlord        User      @relation("LandlordProperties", fields: [landlordId], references: [id])
  
  
  brokerId        String?
  broker          User?     @relation("BrokerProperties", fields: [brokerId], references: [id])
  


  regionId        String?
  region          Region?   @relation(fields: [regionId], references: [id])

  zoneId          String?
  zone            Zone?     @relation(fields: [zoneId], references: [id])

  cityId          String?
  city            City?     @relation(fields: [cityId], references: [id])
  

  subcityId       String?
  subcity         Subcity?  @relation(fields: [subcityId], references: [id])
  

  woredaId        String?
  woreda          Woreda?   @relation(fields: [woredaId], references: [id])
  

  kebeleId        String?
  kebele          Kebele?   @relation(fields: [kebeleId], references: [id])
  

  houseNumber     String?   @map("house_number")
  streetName      String?   @map("street_name")
  landmark        String?   @map("landmark") 
  

  latitude        Float?    @map("latitude")
  longitude       Float?    @map("longitude")
  googleMapsUrl   String?   @map("google_maps_url")
  

  fullAddress     String?   @map("full_address")
  
  
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedBy      String?   @map("verified_by") 
  verifiedAt      DateTime? @map("verified_at")
  verificationDocument String? @map("verification_document") 
  

  kebeleSeal      String?   @map("kebele_seal") 
  sealAppliedAt   DateTime? @map("seal_applied_at")
  sealExpiresAt   DateTime? @map("seal_expires_at")
  

  verificationHistory Json? @map("verification_history") 
  

  viewCount       Int       @default(0) @map("view_count")
  favoriteCount   Int       @default(0) @map("favorite_count")
  inquiryCount    Int       @default(0) @map("inquiry_count")

  
  availableFrom   DateTime? @map("available_from") 
  isActive        Boolean   @default(true) @map("is_active")
  featured        Boolean   @default(false) @map("featured") 
  priority        Int       @default(0) @map("priority") 
  

  
  images          PropertyImage[]
  features        PropertyFeature[]
  favorites       Favorite[]
  inquiries       PropertyInquiry[]
  verifiedProperties VerifiedProperty[]
  contracts       Contract[]


  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  

  @@index([landlordId])
  @@index([brokerId])
  @@index([status])
  @@index([propertyType])
  @@index([isVerified])
  @@index([cityId])
  @@index([subcityId])
  @@index([woredaId])
  @@index([kebeleId])
  @@index([monthlyRent])
  @@index([createdAt])
  
  @@map("properties")
}


model PropertyImage {
  id              String    @id @default(cuid())
  
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  url             String    @map("url")
  thumbnailUrl    String?   @map("thumbnail_url")
  caption         String?   @map("caption")
  
  isPrimary       Boolean   @default(false) @map("is_primary")
  order           Int       @default(0) @map("order")
  
  // የፎቶ መረጃ
  fileSize        Int?      @map("file_size") // በባይት
  mimeType        String?   @map("mime_type")
  width           Int?      @map("width")
  height          Int?      @map("height")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  @@index([propertyId])
  @@index([isPrimary])
  @@map("property_images")
}


model PropertyFeature {
  id              String    @id @default(cuid())
  
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  name            String    @map("name") 
  category        String?   @map("category")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("property_features")
}


model Favorite {
  id              String    @id @default(cuid())
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("favorites")
}


model PropertyInquiry {
  id              String    @id @default(cuid())
  
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  userId          String?   
  user            User?     @relation(fields: [userId], references: [id])
  
 
  guestName       String?   @map("guest_name")
  guestEmail      String?   @map("guest_email")
  guestPhone      String?   @map("guest_phone")
  
  message         String    @map("message")
  
 
  status          InquiryStatus @default(PENDING) @map("status")
  

  response        String?   @map("response")
  respondedBy     String?   @map("responded_by") 
  respondedAt     DateTime? @map("responded_at")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([propertyId])
  @@index([userId])
  @@index([status])
  @@map("property_inquiries")
}


enum PropertyType {
  APARTMENT        
  HOUSE            
  VILLA           
  STUDIO           
  COMMERCIAL       
  OFFICE           
  WAREHOUSE        
  LAND             
}


enum PropertyStatus {
  AVAILABLE        
  RENTED           
  UNDER_MAINTENANCE 
  UNAVAILABLE      
  PENDING_VERIFICATION 
}


enum InquiryStatus {
  PENDING         
  RESPONDED        
  CLOSED           
  SPAM             
}

// Contract Model - የኪራይ ውል
model Contract {
  id              String    @id @default(cuid())
  contractNumber  String    @unique @map("contract_number")
  
  // የውል ወገኖች
  propertyId      String    @map("property_id")
  property        Property  @relation(fields: [propertyId], references: [id])
  
  tenantId        String    @map("tenant_id")
  tenant          User      @relation("TenantContracts", fields: [tenantId], references: [id])
  
  landlordId      String    @map("landlord_id")
  landlord        User      @relation("LandlordContracts", fields: [landlordId], references: [id])
  
  brokerId        String?   @map("broker_id")
  broker          User?     @relation("BrokerContracts", fields: [brokerId], references: [id])
  
  // የኪራይ ዝርዝሮች
  monthlyRent     Float     @map("monthly_rent")
  securityDeposit Float     @map("security_deposit")
  paymentDay      Int       @default(1) @map("payment_day")
  
  // የውል ቀናት
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  
  // ልዩ ሁኔታዎች
  termsAndConditions String? @map("terms_and_conditions")
  specialClauses  Json?     @map("special_clauses") // ልዩ ውሎች በJSON
  
  // የውል ሁኔታ
  status          ContractStatus @default(DRAFT)
  
  // የፊርማ ሁኔታዎች
  landlordSigned  Boolean   @default(false) @map("landlord_signed")
  tenantSigned    Boolean   @default(false) @map("tenant_signed")
  brokerSigned    Boolean   @default(false) @map("broker_signed")
  
  landlordSignedAt DateTime? @map("landlord_signed_at")
  tenantSignedAt   DateTime? @map("tenant_signed_at")
  brokerSignedAt   DateTime? @map("broker_signed_at")
  
  // የቀበሌ ማረጋገጫ
  kebeleApproved  Boolean   @default(false) @map("kebele_approved")
  kebeleApprovedBy String?   @map("kebele_approved_by")
  kebeleApprovedAt DateTime? @map("kebele_approved_at")
  kebeleSeal      String?   @map("kebele_seal")
  kebeleNotes     String?   @map("kebele_notes")
  
  // የሰነድ ማመንጫ
  pdfUrl          String?   @map("pdf_url")
  pdfVersion      Int       @default(1) @map("pdf_version")
  
  // የማቋረጫ መረጃ
  terminatedAt    DateTime? @map("terminated_at")
  terminationReason String?  @map("termination_reason")
  terminationBy   String?   @map("termination_by")
  
  // የማደስ መረጃ
  renewalCount    Int       @default(0) @map("renewal_count")
  lastRenewedAt   DateTime? @map("last_renewed_at")
  
  // ሌሎች
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // ግንኙነቶች
  payments        PaymentSchedule[]
  paymentHistory  PaymentHistory[]
  contractDocuments ContractDocument[]
  notifications   ContractNotification[]
  
  @@index([contractNumber])
  @@index([propertyId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("contracts")
}

// PaymentSchedule - ወርሃዊ ክፍያ መርሐ ግብር
model PaymentSchedule {
  id              String    @id @default(cuid())
  
  contractId      String    @map("contract_id")
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  // የክፍያ ዝርዝሮች
  dueDate         DateTime  @map("due_date")
  amount          Float     @map("amount")
  paymentType     PaymentType @default(RENT) @map("payment_type")
  
  // ክፍያ ሁኔታ
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime? @map("paid_at")
  paidAmount      Float?    @map("paid_amount")
  
  // ቅጣት ክፍያ (ከዘገየ)
  penaltyAmount   Float?    @map("penalty_amount")
  penaltyAppliedAt DateTime? @map("penalty_applied_at")
  
  // የክፍያ መረጃ
  transactionId   String?   @map("transaction_id")
  paymentMethod   String?   @map("payment_method")
  receiptUrl      String?   @map("receipt_url")
  
  // ማስታወሻ
  notes           String?   @map("notes")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // ግንኙነቶች
  paymentHistory  PaymentHistory[] @relation("ScheduleHistory")  
  @@unique([contractId, dueDate])
  @@index([contractId])
  @@index([status])
  @@index([dueDate])
  @@map("payment_schedules")
}

// PaymentHistory - የተከፈሉ ክፍያዎች ታሪክ
model PaymentHistory {
  id              String    @id @default(cuid())
  
  contractId      String    @map("contract_id")
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  scheduleId      String?   @map("schedule_id")
  schedule        PaymentSchedule? @relation("ScheduleHistory", fields: [scheduleId], references: [id])
  
  // የክፍያ ዝርዝሮች
  amount          Float     @map("amount")
  paidAt          DateTime  @map("paid_at")
  paymentType     PaymentType @default(RENT)
  
  // የክፍያ ዘዴ
  paymentMethod   String    @map("payment_method") // tele_birr, cbe_birr, cash, bank_transfer
  transactionId   String?   @map("transaction_id")
  transactionRef  String?   @map("transaction_ref")
  
  // ተከፋይ መረጃ
  paidBy          String    @map("paid_by") // userId
  paidByName      String?   @map("paid_by_name")
  
  // ተቀባይ መረጃ
  receivedBy      String?   @map("received_by")
  receivedByName  String?   @map("received_by_name")
  
  // ቅጣት ክፍያ ከሆነ
  isPenalty       Boolean   @default(false) @map("is_penalty")
  originalAmount  Float?    @map("original_amount")
  penaltyAmount   Float?    @map("penalty_amount")
  
  // ደረሰኝ
  receiptUrl      String?   @map("receipt_url")
  receiptNumber   String?   @map("receipt_number")
  
  // ማስታወሻ
  notes           String?   @map("notes")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  @@index([contractId])
  @@index([scheduleId])
  @@index([transactionId])
  @@index([paidAt])
  @@map("payment_history")
}

// ContractDocument - ከውል ጋር የተያያዙ ሰነዶች
model ContractDocument {
  id              String    @id @default(cuid())
  
  contractId      String    @map("contract_id")
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  documentType    DocumentType @default(CONTRACT)
  title           String    @map("title")
  description     String?   @map("description")
  
  fileUrl         String    @map("file_url")
  fileName        String    @map("file_name")
  fileSize        Int?      @map("file_size")
  mimeType        String?   @map("mime_type")
  
  uploadedBy      String    @map("uploaded_by")
  uploadedAt      DateTime  @default(now()) @map("uploaded_at")
  
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedBy      String?   @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")
  
  @@index([contractId])
  @@index([documentType])
  @@map("contract_documents")
}

// ContractNotification - ከውል ጋር የተያያዙ ማሳሰቢያዎች
model ContractNotification {
  id              String    @id @default(cuid())
  
  contractId      String    @map("contract_id")
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  // የማሳሰቢያ ዝርዝሮች
  notificationType NotificationType @default(PAYMENT_REMINDER)
  title           String    @map("title")
  message         String    @map("message")
  
  // ተቀባይ
  recipientId     String    @map("recipient_id")
  recipientRole   String    @map("recipient_role") // TENANT, LANDLORD, BROKER
  
  // ማሳሰቢያ ሁኔታ
  status          NotificationStatus @default(PENDING)
  sentAt          DateTime? @map("sent_at")
  
  // የመላኪያ ዘዴዎች
  sentViaEmail    Boolean   @default(false) @map("sent_via_email")
  sentViaSms      Boolean   @default(false) @map("sent_via_sms")
  sentViaPush     Boolean   @default(false) @map("sent_via_push")
  sentViaInApp    Boolean   @default(false) @map("sent_via_in_app")
  
  // ውጤት
  errorMessage    String?   @map("error_message")
  
  // ቀጠሮ
  scheduledFor    DateTime? @map("scheduled_for")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([contractId])
  @@index([recipientId])
  @@index([status])
  @@index([notificationType])
  @@map("contract_notifications")
}

// Contract Status Enum
enum ContractStatus {
  DRAFT             // ረቂቅ
  PENDING_TENANT    // ተከራይ ፊርማ ይጠበቃል
  PENDING_LANDLORD  // አከራይ ፊርማ ይጠበቃል
  PENDING_BROKER    // ደላላ ፊርማ ይጠበቃል
  PENDING_KEBELE    // የቀበሌ ማረጋገጫ ይጠበቃል
  ACTIVE            // ንቁ
  EXPIRED           // ጊዜው ያለፈበት
  TERMINATED        // ተቋርጧል
  DISPUTED          // ክርክር አለበት
}

// Payment Type Enum
enum PaymentType {
  RENT              // ኪራይ
  SECURITY_DEPOSIT  // ተያዥ ገንዘብ
  PENALTY           // ቅጣት
  COMMISSION        // ኮሚሽን (ለደላላ)
  RENEWAL_FEE       // የማደስ ክፍያ
}

// Payment Status Enum
enum PaymentStatus {
  PENDING           // በመጠባበቅ ላይ
  PAID              // ተከፍሏል
  OVERDUE           // ቀኑ አልፎበታል
  PARTIAL           // በከፊል ተከፍሏል
  CANCELLED         // ተሰርዟል
  REFUNDED          // ተመልሷል
}

// Document Type Enum
enum DocumentType {
  CONTRACT          // ዋናው ውል
  AMENDMENT         // ማሻሻያ
  ADDENDUM          // ተጨማሪ ሰነድ
  ID_PROOF          // የማንነት ማረጋገጫ
  PROPERTY_DOCUMENT // የቤት ሰነድ
  RECEIPT           // ደረሰኝ
  OTHER             // ሌላ
}

// Notification Type Enum
enum NotificationType {
  PAYMENT_REMINDER      // የክፍያ ማሳሰቢያ
  PAYMENT_RECEIVED      // ክፍያ ተቀብሏል
  CONTRACT_SIGNED       // ውል ተፈርሟል
  CONTRACT_APPROVED     // ውል ተጸድቋል
  CONTRACT_EXPIRING     // ውል ሊያበቃ ነው
  CONTRACT_TERMINATED   // ውል ተቋርጧል
  MAINTENANCE_REQUEST   // ጥገና ጥያቄ
  GENERAL               // አጠቃላይ
}

// Notification Status Enum
enum NotificationStatus {
  PENDING           // በመጠባበቅ ላይ
  SENT              // ተልኳል
  FAILED            // አልተላከም
  READ              // ተነቧል
  SCHEDULED         // ቀጠሮ ተይዞለታል
}